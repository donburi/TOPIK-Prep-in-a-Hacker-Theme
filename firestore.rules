rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User subtree access
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /gameState/{stateId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /learnedItems/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Progress Tracking (top-level collection with userId field)
    match /userProgress/{progressId} {
      allow list: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow get: if request.auth != null && (progressId.startsWith(request.auth.uid + "_") || (resource != null && resource.data.userId == request.auth.uid));
      allow write: if request.auth != null && (progressId.startsWith(request.auth.uid + "_") || (resource != null && resource.data.userId == request.auth.uid) || (request.resource != null && request.resource.data.userId == request.auth.uid));
    }

    // Learned Items (fallback for top-level if code uses it)
    match /learnedItems/{itemId} {
      allow list: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow get: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}

